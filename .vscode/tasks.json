{
  "version": "2.0.0",
  "tasks": [
    {
      "type": "npm",
      "script": "build",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": "$esbuild"
    },
    {
      "type": "npm",
      "script": "typecheck",
      "problemMatcher": "$tsc-watch",
      "group": "build"
    },
    {
      "type": "npm",
      "script": "test",
      "problemMatcher": [],
      "group": {
        "kind": "test",
        "isDefault": true
      }
    }
  ]
}
