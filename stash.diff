+/* Action Bar */
+.action-bar {
+  display: flex;
+  flex-wrap: wrap;
+  gap: 4px;
+  padding: 8px 10px;
+  border-bottom: 1px solid var(--border-color);
+  background: rgba(0, 0, 0, 0.6);
+  position: relative;
+  z-index: 5;
+}
+
+.action-btn {
+  font-size: 9px;
+  padding: 4px 8px;
+  background: transparent;
+  color: var(--accent);
+  border: 1px solid var(--border-color);
+  cursor: pointer;
+  font-family: var(--font-mono);
+  text-transform: uppercase;
+  letter-spacing: 0.5px;
+  white-space: nowrap;
+  transition: all 0.15s;
+}
+
+.action-btn:hover {
+  background: var(--accent);
+  color: var(--bg-color);
+  border-color: var(--accent);
+}
+
+.action-btn::before {
+  display: none;
+}
+
+/* Panel System */
+.panel {
+  display: none;
+  flex-direction: column;
+  flex: 1;
+  overflow: hidden;
+  position: relative;
+  z-index: 3;
+}
+
+.panel-active {
+  display: flex;
+}
+
+/* Panel Header */
+.panel-header {
+  display: flex;
+  justify-content: space-between;
+  align-items: center;
+  padding: 8px 12px;
+  border-bottom: 1px solid var(--border-color);
+  font-size: 10px;
+  letter-spacing: 1px;
+  color: var(--accent);
+  background: rgba(0, 0, 0, 0.4);
+}
+
+.panel-close {
+  background: none;
+  border: 1px solid var(--border-color);
+  color: var(--fg-color);
+  cursor: pointer;
+  font-size: 10px;
+  padding: 2px 6px;
+  font-family: var(--font-mono);
+}
+
+.panel-close:hover {
+  border-color: var(--accent);
+  color: var(--accent);
+}
+
+.panel-close::before {
+  display: none;
+}
+
+/* Session List */
+.session-list {
+  flex: 1;
+  overflow-y: auto;
+  padding: 8px;
+  display: flex;
+  flex-direction: column;
+  gap: 4px;
+}
+
+.session-list::-webkit-scrollbar { width: 6px; }
+.session-list::-webkit-scrollbar-track { background: var(--bg-color); }
+.session-list::-webkit-scrollbar-thumb { background: var(--border-color); }
+
+.session-item {
+  display: flex;
+  align-items: center;
+  gap: 8px;
+  padding: 8px 10px;
+  border: 1px solid var(--border-color);
+  cursor: pointer;
+  font-size: 11px;
+  transition: all 0.15s;
+}
+
+.session-item:hover {
+  border-color: var(--accent);
+  background: rgba(0, 255, 65, 0.05);
+}
+
+.session-icon {
+  color: var(--accent);
+  font-size: 14px;
+  flex-shrink: 0;
+}
+
+.session-info {
+  display: flex;
+  flex-direction: column;
+  gap: 2px;
+  min-width: 0;
+}
+
+.session-label {
+  color: var(--fg-color);
+  overflow: hidden;
+  text-overflow: ellipsis;
+  white-space: nowrap;
+}
+
+.session-meta {
+  font-size: 9px;
+  color: var(--border-color);
+}
+
+.session-empty {
+  padding: 20px;
+  text-align: center;
+  color: var(--border-color);
+  font-size: 11px;
+}
+
+/* Status Panel */
+.status-content {
+  flex: 1;
+  overflow: auto;
+  padding: 12px;
+  margin: 0;
+  font-family: var(--font-mono);
+  font-size: 11px;
+  color: var(--fg-color);
+  white-space: pre-wrap;
+  word-wrap: break-word;
+}
+
+.status-content::-webkit-scrollbar { width: 6px; }
+.status-content::-webkit-scrollbar-track { background: var(--bg-color); }
+.status-content::-webkit-scrollbar-thumb { background: var(--border-color); }
+
