+  it("should initialize and register tools", () => {
+    const socketPath = "/tmp/fake.sock";
+    const server = new CmdMcpServer(socketPath, [terminalTool]);
+
+    expect(server).toBeDefined();
+    expect(net.createServer).toHaveBeenCalled();
+  });
