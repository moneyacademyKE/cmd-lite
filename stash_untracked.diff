+  createServer: vi.fn(() => ({
+    on: vi.fn(),
+    listen: vi.fn(),
+    close: vi.fn(),
+  })),
+}));
+
+vi.mock("vscode", () => ({
+  env: { appName: "mock" },
+  window: {
+    createOutputChannel: vi.fn(() => ({
+      appendLine: vi.fn(),
+      show: vi.fn(),
+    })),
